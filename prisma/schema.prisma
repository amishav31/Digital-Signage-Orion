generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  SUPER_ADMIN
  PLATFORM_ADMIN
  SALES
  SUPPORT
}

enum OrganizationRole {
  ORG_ADMIN
  MANAGER
  CONTENT_EDITOR
  ANALYST_VIEWER
}

enum FeatureKey {
  DASHBOARD
  ASSETS
  PLAYLISTS
  CAMPAIGNS
  SCHEDULE
  TICKERS
  DEVICES
  REPORTS
  TEAM
  SETTINGS
}

enum FeatureAccessLevel {
  NONE
  VIEW
  EDIT
  MANAGE
  CONTROL
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum OrganizationStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum InvitationScope {
  ORGANIZATION
}

enum CampaignStatus {
  ACTIVE
  DRAFT
  SCHEDULED
}

enum PlaylistStatus {
  ACTIVE
  PAUSED
  DRAFT
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  WARNING
}

enum TickerSpeed {
  SLOW
  NORMAL
  FAST
}

enum TickerStyle {
  CLASSIC
  NEON
  GRADIENT
  MINIMAL
}

enum TickerStatus {
  ACTIVE
  PAUSED
  DRAFT
}

enum TickerPriority {
  LOW
  NORMAL
  URGENT
}

enum ScheduleStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  PAUSED
}

enum SchedulePriority {
  LOW
  NORMAL
  HIGH
}

enum ProofOfPlayStatus {
  VERIFIED
  FAILED
}

enum AssetType {
  IMAGE
  VIDEO
  HTML
  DOCUMENT
  URL
}

enum AssetStatus {
  UPLOADING
  READY
  ERROR
}

model User {
  id               String                   @id @default(cuid())
  email            String                   @unique
  fullName         String
  passwordHash     String
  platformRole     PlatformRole?
  status           UserStatus               @default(ACTIVE)
  memberships      OrganizationMembership[]
  sentInvitations  Invitation[]             @relation("InvitationSender")
  uploadedAssets   Asset[]                  @relation("AssetUploader")
  auditLogs        AuditLog[]               @relation("AuditActor")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model Organization {
  id                 String                   @id @default(cuid())
  name               String
  slug               String                   @unique
  status             OrganizationStatus       @default(DRAFT)
  primaryContactName String?
  primaryContactEmail String?
  salesNotes         String?
  memberships        OrganizationMembership[]
  invitations        Invitation[]
  assets             Asset[]
  campaigns          Campaign[]
  playlists          Playlist[]
  scheduleEvents     ScheduleEvent[]
  devices            Device[]
  tickers            Ticker[]
  proofOfPlayLogs    ProofOfPlayLog[]
  auditLogs          AuditLog[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
}


model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  description    String
  assetCount     Int            @default(0)
  status         CampaignStatus @default(DRAFT)
  screens        Int            @default(0)
  impressions    Int            @default(0)
  color          String         @default("#4ade80")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  playlistLinks  PlaylistCampaign[]
  campaignAssets CampaignAsset[]

  @@index([organizationId, createdAt])
}

model Playlist {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  status         PlaylistStatus @default(DRAFT)
  screens        Int            @default(0)
  color          String         @default("#4ade80")
  lastPlayedAt   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          PlaylistItem[]
  campaignLinks  PlaylistCampaign[]
  devices        Device[]

  @@index([organizationId, createdAt])
}

model PlaylistCampaign {
  id         String   @id @default(cuid())
  playlistId String
  campaignId String
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([playlistId, campaignId])
  @@index([campaignId])
  @@index([playlistId, position])
}

model PlaylistItem {
  id              String   @id @default(cuid())
  playlistId      String
  name            String
  type            String
  durationSeconds Int
  position        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  playlist        Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, position])
}

model ScheduleEvent {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  campaign       String
  startTime      String
  endTime        String
  days           String[]
  screens        Int              @default(0)
  status         ScheduleStatus   @default(SCHEDULED)
  color          String           @default("#4ade80")
  priority       SchedulePriority @default(NORMAL)
  recurring      Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model Device {
  id              String           @id @default(cuid())
  organizationId  String?
  name            String
  status         DeviceStatus @default(OFFLINE)
  location       String       @default("Pending")
  ip             String       @default("Pending")
  resolution     String       @default("1920x1080")
  uptime         String       @default("0s")
  cpu            Int          @default(0)
  ram            Int          @default(0)
  temp           Int          @default(0)
  lastSync       String       @default("Awaiting first sync")
  os             String       @default("Unknown")
  currentContent String?
  currentPlaylistId String?

  // Pairing fields
  pairingCode    String?      @unique
  deviceToken    String?      @unique
  hardwareId     String?      @unique
  isPaired       Boolean      @default(false)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  currentPlaylist Playlist?        @relation(fields: [currentPlaylistId], references: [id], onDelete: SetNull)
  proofOfPlayLogs ProofOfPlayLog[]

  @@index([organizationId, createdAt])
  @@index([organizationId, currentPlaylistId])
}

model Ticker {
  id             String         @id @default(cuid())
  organizationId String
  text           String
  speed          TickerSpeed    @default(NORMAL)
  style          TickerStyle    @default(NEON)
  color          String         @default("#00e5ff")
  status         TickerStatus   @default(DRAFT)
  priority       TickerPriority @default(NORMAL)
  screens        Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model ProofOfPlayLog {
  id              String            @id @default(cuid())
  organizationId  String
  deviceId        String?
  device          String
  content         String
  assetName       String            @default("")
  playlistName    String?
  campaignName    String?
  status          ProofOfPlayStatus
  timestamp       DateTime
  startTime       DateTime
  endTime         DateTime?
  durationSeconds Int?
  createdAt       DateTime          @default(now())

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deviceRef       Device?           @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([organizationId, timestamp])
  @@index([organizationId, startTime])
  @@index([organizationId, deviceId, startTime])
}

model OrganizationMembership {
  id             String             @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizationRole
  status         MembershipStatus   @default(ACTIVE)
  invitedById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions    MembershipFeaturePermission[]

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([role])
}

model MembershipFeaturePermission {
  id            String             @id @default(cuid())
  membershipId  String
  featureKey    FeatureKey
  accessLevel   FeatureAccessLevel
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  membership    OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, featureKey])
  @@index([featureKey])
}

model Invitation {
  id              String             @id @default(cuid())
  email           String
  token           String             @unique
  scope           InvitationScope
  status          InvitationStatus   @default(PENDING)
  organizationId  String
  role            OrganizationRole
  permissions     Json?
  invitedById     String
  acceptedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy       User               @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
}

model AuditLog {
  id             String        @id @default(cuid())
  actorUserId    String?
  organizationId String?
  action         String
  targetType     String
  targetId       String?
  summary        String
  metadata       Json?
  createdAt      DateTime      @default(now())

  actor          User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
}

model Asset {
  id                     String        @id @default(cuid())
  organizationId         String
  name                   String
  type                   AssetType
  status                 AssetStatus   @default(UPLOADING)
  mimeType               String
  fileSize               Int           @default(0)
  s3Key                  String?       @unique
  url                    String?
  defaultDurationSeconds Int?
  width                  Int?
  height                 Int?
  durationMs             Int?
  uploadedById           String
  tags                   String[]      @default([])
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy       User          @relation("AssetUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  campaignAssets   CampaignAsset[]

  @@index([organizationId, createdAt])
  @@index([organizationId, type])
}

model CampaignAsset {
  id              String   @id @default(cuid())
  campaignId      String
  assetId         String
  position        Int
  durationSeconds Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([campaignId, assetId])
  @@index([campaignId, position])
}
