DATABASE_URL="postgresql://postgres:postgres@localhost:5432/orion_platform?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=3001

# S3 Storage (auto-uses local disk when S3_ACCESS_KEY_ID is still the placeholder)
S3_USE_LOCAL_STORAGE=true
S3_BUCKET=orion-assets
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_ENDPOINT=                        # optional, for MinIO/DO Spaces
S3_FORCE_PATH_STYLE=false           # set true for MinIO
